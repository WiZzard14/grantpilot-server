NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

MONGODB_URI=PASTE_YOUR_WORKING_MONGODB_ATLAS_URI_HERE
MONGODB_DB_NAME=grantpilot_ai

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters-before-running
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret-before-running
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
COOKIE_DOMAIN=

# Firebase Authentication server verification.
# No service-account JSON, client email, or private key is required.
FIREBASE_PROJECT_ID=recipehub-142f4

# Free AI provider. Keep this key only on the server.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional paid backup provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

ADMIN_EMAIL=admin@grantpilot.demo
ADMIN_PASSWORD=GrantPilotAdmin2026!
ADMIN_NAME=GrantPilot Admin
ADMIN_IMAGE=https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=400&auto=format&fit=crop
